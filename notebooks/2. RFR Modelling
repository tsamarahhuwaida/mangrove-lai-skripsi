        "}.items():\n",
        "    unit = \"%\" if \"%\" in metrik else \"\"\n",
        "    print(f\"    {metrik:<22} {vals[0]:>11.4f}{unit} {vals[1]:>11.4f}{unit} {vals[2]:>11.4f}{unit}\")\n",
        "\n",
        "# =============================================================================\n",
        "# 10. DASBOR RINGKASAN\n",
        "# =============================================================================\n",
        "print(\"\\n[10] Dasbor Ringkasan...\")\n",
        "fig = plt.figure(figsize=(14, 7))\n",
        "gs  = GridSpec(2, 3, figure=fig, hspace=0.45, wspace=0.35)\n",
        "\n",
        "ax_m = fig.add_subplot(gs[:, 0])\n",
        "metric_labels = [\"RMSE Pelatihan\",\"RMSE Validasi\",\"RMSE Pengujian\",\n",
        "                 \"R² Pelatihan\",\"R² Validasi\",\"R² Pengujian\"]\n",
        "metric_values = [tr_rmse, vl_rmse, ts_rmse, tr_r2, vl_r2, ts_r2]\n",
        "m_colors = [\"#2ecc71\"]*3 + [\"#3498db\"]*3\n",
        "b = ax_m.barh(metric_labels, metric_values, color=m_colors,\n",
        "              edgecolor=\"white\", height=0.6)\n",
        "for bar, val in zip(b, metric_values):\n",
        "    ax_m.text(bar.get_width() + 0.005, bar.get_y() + bar.get_height()/2,\n",
        "              f\"{val:.4f}\", va=\"center\", ha=\"left\", fontsize=8)\n",
        "ax_m.set_title(\"Ringkasan Metrik Model\", fontsize=11, fontweight=\"bold\")\n",
        "ax_m.set_xlim(0, max(metric_values) * 1.35)\n",
        "ax_m.grid(True, axis=\"x\", alpha=0.3)\n",
        "\n",
        "ax_t = fig.add_subplot(gs[0, 1:])\n",
