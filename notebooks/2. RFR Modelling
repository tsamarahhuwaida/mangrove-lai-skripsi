        "    ax = fig.add_subplot(gs[1, col])\n",
        "    ax.hist(resid, bins=15, color=color, alpha=0.7, edgecolor=\"white\", density=True)\n",
        "    mu_r, std_r = resid.mean(), resid.std()\n",
        "    x_norm = np.linspace(resid.min(), resid.max(), 200)\n",
        "    ax.plot(x_norm, norm.pdf(x_norm, mu_r, std_r),\n",
        "            color=\"black\", linewidth=2, label=f\"N(μ={mu_r:.3f}, σ={std_r:.3f})\")\n",
