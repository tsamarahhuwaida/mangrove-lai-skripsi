        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as mpatches\n",
        "from matplotlib.gridspec import GridSpec\n",
        "from scipy.stats import norm, probplot, linregress\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.gaussian_process import GaussianProcessRegressor\n",
        "from sklearn.gaussian_process.kernels import Matern\n",
        "from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error\n",
        "from sklearn.tree import plot_tree\n",
        "import os\n",
        "import seaborn as sns\n",
        "\n",
        "# =============================================================================\n",
        "# 0. KONFIGURASI — SESUAIKAN DENGAN KEBUTUHAN\n",
        "# =============================================================================\n",
        "# ⚠️ Sesuaikan CSV_PATH dan OUTPUT_DIR dengan lokasi file di Google Drive Anda.\n",
        "# =============================================================================\n",
        "\n",
        "import os\n",
        "\n",
        "# ── Input: dataset sampel LAI ─────────────────────────────────────────────────\n",
        "CSV_PATH = \"/content/drive/MyDrive/YOUR_PROJECT_FOLDER/dataset/lai_sample.csv\"\n",
        "\n",
        "# ── Indeks kolom dalam CSV (0-based) ──────────────────────────────────────────\n",
        "DEP_COL_IDX    = 1    # kolom variabel dependen (LAI)\n",
        "LABEL_COL_IDX  = 2    # kolom label split (Training/Validation/Test)\n",
        "FEAT_COL_START = 5    # kolom prediktor: mulai dari indeks ini\n",
        "FEAT_COL_END   = 13   # kolom prediktor: sampai indeks ini (eksklusif)\n",
        "\n",
        "# ── Label split dataset ───────────────────────────────────────────────────────\n",
        "TRAIN_LABEL = \"Training\"\n",
        "VAL_LABEL   = \"Validation\"\n",
        "TEST_LABEL  = \"Test\"\n",
        "\n",
        "# ── Parameter Bayesian Optimization ──────────────────────────────────────────\n",
        "N_INIT_POINTS       = 20    # jumlah titik inisialisasi acak\n",
        "N_BAYES_CALLS       = 100   # jumlah iterasi optimasi\n",
        "MAX_TREE_DEPTH_PLOT = 3     # kedalaman maksimum pohon untuk visualisasi\n",
        "\n",
        "# ── Output: folder model dan hasil evaluasi ───────────────────────────────────\n",
        "OUTPUT_DIR = \"/content/drive/MyDrive/YOUR_PROJECT_FOLDER/model_output\"\n",
        "\n",
        "# ── Search space hyperparameter ───────────────────────────────────────────────\n",
        "PARAM_BOUNDS = {\n",
        "    \"n_estimators\":      (100,  2000),\n",
        "    \"max_depth\":         (2,    15),\n",
        "    \"min_samples_split\": (2,    30),\n",
        "    \"min_samples_leaf\":  (1,    15),\n",
        "    \"max_features\":      (0.3,  0.8),\n",
        "}\n",
        "\n",
        "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
        "assert os.path.exists(OUTPUT_DIR), f\"GAGAL membuat folder output: {OUTPUT_DIR}\"\n",
        "print(f\"✅ Direktori output siap: {OUTPUT_DIR}\")\n",
        "\n",
        "# =============================================================================\n",
        "# 1. MEMUAT & MEMBERSIHKAN DATA\n",
        "# =============================================================================\n",
        "print(\"=\" * 65)\n",
        "print(\"  REGRESI RANDOM FOREST -- PREDIKSI INDEKS LUAS DAUN (LAI)\")\n",
        "print(\"=\" * 65)\n",
        "print(\"\\n[1] Memuat data...\")\n",
        "df = pd.read_csv(CSV_PATH, header=0, delimiter=';', decimal=',')\n",
        "\n",
        "for col in df.columns:\n",
        "    if df[col].dtype == object:\n",
        "        try:\n",
        "            df[col] = df[col].str.replace(',', '.', regex=False).astype(float)\n",
        "        except (ValueError, AttributeError):\n",
        "            pass\n",
        "print(f\"    Total baris        : {len(df)}\")\n",
        "\n",
        "y_col     = df.columns[DEP_COL_IDX]\n",
        "lbl_col   = df.columns[LABEL_COL_IDX]\n",
        "feat_cols = list(df.columns[FEAT_COL_START:FEAT_COL_END])\n",
        "num_col   = df.columns[0]   # kolom Nomor Samp\n",
        "\n",
        "print(f\"    Variabel dependen  : {y_col}\")\n",
        "print(f\"    Kolom label        : {lbl_col}\")\n",
        "print(f\"    Kolom prediktor    : {feat_cols}\")\n",
        "print(f\"    Label unik         : {df[lbl_col].unique().tolist()}\")\n",
        "\n",
        "train_df_orig = df[df[lbl_col].str.lower() == TRAIN_LABEL.lower()]\n",
        "val_df        = df[df[lbl_col].str.lower() == VAL_LABEL.lower()]\n",
        "test_df       = df[df[lbl_col].str.lower() == TEST_LABEL.lower()]\n",
        "\n",
        "# Cek agar tidak kosong\n",
        "if len(train_df_orig) == 0:\n",
        "    raise ValueError(f\"❌ Tidak ada sampel pelatihan! Cek TRAIN_LABEL='{TRAIN_LABEL}'\")\n",
        "if len(val_df) == 0:\n",
        "    raise ValueError(f\"❌ Tidak ada sampel validasi! Cek VAL_LABEL='{VAL_LABEL}'\")\n",
        "if len(test_df) == 0:\n",
        "    raise ValueError(f\"❌ Tidak ada sampel pengujian! Cek TEST_LABEL='{TEST_LABEL}'\")\n",
        "\n",
        "print(f\"\\n    Sampel pelatihan   : {len(train_df_orig)}\")\n",
        "print(f\"    Sampel validasi    : {len(val_df)}\")\n",
        "print(f\"    Sampel pengujian   : {len(test_df)}\")\n",
        "\n",
        "# =============================================================================\n",
        "# 2. PLOT DISTRIBUSI LAI (DATA ASLI — sebelum duplikasi)\n",
        "# =============================================================================\n",
        "print(\"\\n[2] Membuat plot distribusi LAI (data asli)...\")\n",
        "\n",
        "fig, axes = plt.subplots(1, 3, figsize=(13, 5), sharey=True)\n",
        "split_info = [\n",
        "    (\"Pelatihan\",  train_df_orig, \"#2ecc71\"),\n",
        "    (\"Validasi\",   val_df,        \"#3498db\"),\n",
        "    (\"Pengujian\",  test_df,       \"#e74c3c\"),\n",
        "]\n",
        "for ax, (name, sdf, color) in zip(axes, split_info):\n",
        "    data = sdf[y_col].values\n",
        "    bp = ax.boxplot(data, positions=[1], patch_artist=True,\n",
        "                    medianprops=dict(color=\"orange\", linewidth=2),\n",
        "                    widths=0.45)\n",
        "    bp[\"boxes\"][0].set_facecolor(color)\n",
        "    bp[\"boxes\"][0].set_alpha(0.4)\n",
        "    ax.scatter(np.ones(len(data)) + np.random.uniform(-0.08, 0.08, len(data)),\n",
        "               data, alpha=0.6, color=color, zorder=5, s=35,\n",
        "               edgecolors=\"white\", linewidths=0.5)\n",
        "    ax.set_title(f\"{name}\\n(n={len(data)})\", fontsize=11, fontweight=\"bold\")\n",
        "    ax.set_ylabel(\"LAI\", fontsize=9)\n",
        "    ax.set_xticks([])\n",
        "    ax.grid(True, axis=\"y\", alpha=0.3)\n",
        "    ax.spines[\"top\"].set_visible(False)\n",
        "    ax.spines[\"right\"].set_visible(False)\n",
        "\n",
        "fig.suptitle(\"Distribusi Sampel LAI per Split (Data Asli)\",\n",
        "             fontsize=13, fontweight=\"bold\")\n",
        "fig.tight_layout()\n",
        "fig.savefig(os.path.join(OUTPUT_DIR, \"0_distribusi_lai.png\"),\n",
        "            dpi=150, bbox_inches=\"tight\")\n",
        "plt.close(fig)\n",
        "print(\"    -> Tersimpan: 0_distribusi_lai.png\")\n",
        "\n",
        "# =============================================================================\n",
        "# 3. PERSIAPAN DATA PELATIHAN (tanpa duplikasi)\n",
        "# =============================================================================\n",
        "print(\"\\n[3] Mempersiapkan data pelatihan (tanpa duplikasi)...\")\n",
        "\n",
        "train_df = train_df_orig.copy()\n",
        "\n",
        "print(f\"    Sampel pelatihan   : {len(train_df)} sampel\")\n",
        "\n",
        "X_train = train_df[feat_cols].values.astype(float)\n",
        "y_train = train_df[y_col].values.astype(float)\n",
        "X_val   = val_df[feat_cols].values.astype(float)\n",
        "y_val   = val_df[y_col].values.astype(float)\n",
        "X_test  = test_df[feat_cols].values.astype(float)\n",
        "y_test  = test_df[y_col].values.astype(float)\n",
        "feature_names     = feat_cols\n",
        "selected_features = feat_cols\n",
        "X_train_sel = X_train\n",
        "X_val_sel   = X_val\n",
        "X_test_sel  = X_test\n",
        "\n",
        "# =============================================================================\n",
        "# 4. OPTIMASI HIPERPARAMETER BAYESIAN\n",
        "# =============================================================================\n",
        "print(f\"\\n[4] Optimasi Hiperparameter Bayesian \"\n",
        "      f\"({N_INIT_POINTS} inisialisasi acak + {N_BAYES_CALLS - N_INIT_POINTS} panduan GP)...\")\n",
        "\n",
        "param_names = list(PARAM_BOUNDS.keys())\n",
        "bounds_low  = np.array([PARAM_BOUNDS[p][0] for p in param_names], dtype=float)\n",
        "bounds_high = np.array([PARAM_BOUNDS[p][1] for p in param_names], dtype=float)\n",
        "n_params    = len(param_names)\n",
        "int_params  = {\"n_estimators\", \"max_depth\", \"min_samples_split\", \"min_samples_leaf\"}\n",
        "\n",
        "def denormalize(x_norm):\n",
        "    return bounds_low + x_norm * (bounds_high - bounds_low)\n",
        "\n",
        "def build_rf_and_score(x_raw):\n",
        "    params = dict(zip(param_names, x_raw))\n",
        "    for p in int_params:\n",
        "        params[p] = int(round(params[p]))\n",
        "    rf = RandomForestRegressor(\n",
        "        n_estimators      = params[\"n_estimators\"],\n",
        "        max_depth         = params[\"max_depth\"],\n",
        "        min_samples_split = params[\"min_samples_split\"],\n",
        "        min_samples_leaf  = params[\"min_samples_leaf\"],\n",
        "        max_features      = float(params[\"max_features\"]),\n",
        "        oob_score=False, bootstrap=False, random_state=42, n_jobs=-1\n",
        "    )\n",
        "    rf.fit(X_train_sel, y_train)\n",
        "    y_pred = rf.predict(X_val_sel)\n",
        "    return np.sqrt(mean_squared_error(y_val, y_pred))\n",
        "\n",
        "def expected_improvement(X_cand, gp, y_best, xi=0.01):\n",
        "    mu, sigma = gp.predict(X_cand, return_std=True)\n",
        "    sigma = np.maximum(sigma, 1e-9)\n",
        "    Z  = (y_best - mu - xi) / sigma\n",
        "    ei = (y_best - mu - xi) * norm.cdf(Z) + sigma * norm.pdf(Z)\n",
        "    return ei\n",
        "\n",
        "rng        = np.random.RandomState(42)\n",
        "X_obs_norm = []\n",
        "Y_obs      = []\n",
        "history    = []\n",
        "\n",
        "for i in range(N_INIT_POINTS):\n",
        "    x_norm = rng.uniform(0, 1, n_params)\n",
        "    x_raw  = denormalize(x_norm)\n",
        "    rmse   = build_rf_and_score(x_raw)\n",
        "    X_obs_norm.append(x_norm)\n",
        "    Y_obs.append(rmse)\n",
        "    history.append({\"iterasi\": i+1, \"rmse\": rmse, **dict(zip(param_names, x_raw))})\n",
        "    print(f\"    Inisialisasi {i+1:>3d}/{N_INIT_POINTS} | RMSE Validasi = {rmse:.4f}\")\n",
        "\n",
        "kernel = Matern(nu=2.5)\n",
        "gp = GaussianProcessRegressor(kernel=kernel, alpha=1e-6,\n",
        "                               normalize_y=True, n_restarts_optimizer=5)\n",
        "for i in range(N_INIT_POINTS, N_BAYES_CALLS):\n",
        "    X_arr = np.array(X_obs_norm)\n",
        "    Y_arr = np.array(Y_obs)\n",
        "    gp.fit(X_arr, Y_arr)\n",
        "    X_cand      = rng.uniform(0, 1, (5000, n_params))\n",
        "    ei          = expected_improvement(X_cand, gp, y_best=Y_arr.min())\n",
        "    x_next_norm = X_cand[np.argmax(ei)]\n",
        "    x_next_raw  = denormalize(x_next_norm)\n",
        "    rmse = build_rf_and_score(x_next_raw)\n",
        "    X_obs_norm.append(x_next_norm)\n",
        "    Y_obs.append(rmse)\n",
        "    history.append({\"iterasi\": i+1, \"rmse\": rmse, **dict(zip(param_names, x_next_raw))})\n",
        "    print(f\"    Iterasi {i+1:>3d}/{N_BAYES_CALLS} | RMSE Validasi = {rmse:.4f}\")\n",
        "\n",
        "hist_df   = pd.DataFrame(history)\n",
        "best_idx  = hist_df[\"rmse\"].idxmin()\n",
        "best_rmse = hist_df.loc[best_idx, \"rmse\"]\n",
        "best_params = {}\n",
        "for p in param_names:\n",
        "    v = hist_df.loc[best_idx, p]\n",
        "    best_params[p] = int(round(v)) if p in int_params else float(v)\n",
        "\n",
        "print(f\"\\n    RMSE Validasi Terbaik : {best_rmse:.4f}\")\n",
        "print(f\"    Parameter terbaik     : {best_params}\")\n",
        "\n",
        "running_min = hist_df[\"rmse\"].cummin()\n",
        "fig, axes = plt.subplots(2, 1, figsize=(12, 8),\n",
        "                         gridspec_kw={\"height_ratios\": [3, 1]})\n",
        "ax1 = axes[0]\n",
        "dot_colors = ([\"#f39c12\"] * N_INIT_POINTS +\n",
        "              [\"#3498db\"] * (N_BAYES_CALLS - N_INIT_POINTS))\n",
        "ax1.scatter(hist_df[\"iterasi\"], hist_df[\"rmse\"],\n",
        "            color=dot_colors, alpha=0.7, s=65, zorder=3)\n",
        "ax1.plot(hist_df[\"iterasi\"], running_min,\n",
        "         color=\"#e74c3c\", linewidth=2.5, zorder=4)\n",
        "ax1.axvspan(0.5, N_INIT_POINTS + 0.5, alpha=0.07, color=\"#f39c12\")\n",
        "ax1.legend(handles=[\n",
        "    mpatches.Patch(color=\"#f39c12\", label=\"Evaluasi inisialisasi acak\"),\n",
        "    mpatches.Patch(color=\"#3498db\", label=\"Evaluasi panduan GP\"),\n",
        "    plt.Line2D([0],[0], color=\"#e74c3c\", linewidth=2.5, label=\"Minimum berjalan\"),\n",
        "], fontsize=9)\n",
        "best_iter = int(hist_df.loc[best_idx, \"iterasi\"])\n",
        "ax1.annotate(f\"Terbaik: {best_rmse:.4f}\\n(iterasi {best_iter})\",\n",
        "             xy=(best_iter, best_rmse),\n",
        "             xytext=(best_iter + 2, best_rmse + (hist_df[\"rmse\"].max() - best_rmse) * 0.35),\n",
        "             arrowprops=dict(arrowstyle=\"->\", color=\"#2c3e50\"),\n",
        "             fontsize=9, color=\"#2c3e50\",\n",
        "             bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=\"white\",\n",
        "                       edgecolor=\"#2c3e50\", alpha=0.85))\n",
        "ax1.set_ylabel(\"RMSE (Set Validasi)\", fontsize=11)\n",
        "ax1.set_title(f\"Optimasi Bayesian -- RMSE per Iterasi\\n\"\n",
        "              f\"(RMSE Terbaik = {best_rmse:.4f} pada iterasi {best_iter})\",\n",
        "              fontsize=13, fontweight=\"bold\")\n",
        "ax1.set_xlim(0.5, N_BAYES_CALLS + 0.5)\n",
        "ax1.grid(True, alpha=0.3)\n",
        "ax2 = axes[1]\n",
        "roll_std = hist_df[\"rmse\"].rolling(5, min_periods=1).std().fillna(0)\n",
        "ax2.fill_between(hist_df[\"iterasi\"], roll_std, alpha=0.5, color=\"#9b59b6\")\n",
        "ax2.plot(hist_df[\"iterasi\"], roll_std, color=\"#8e44ad\", linewidth=1.5)\n",
        "ax2.set_xlabel(\"Iterasi\", fontsize=11)\n",
        "ax2.set_ylabel(\"Std Bergerak\\n(jendela=5)\", fontsize=9)\n",
        "ax2.set_title(\"Variansi Eksplorasi (Std Bergerak RMSE)\", fontsize=10)\n",
        "ax2.set_xlim(0.5, N_BAYES_CALLS + 0.5)\n",
        "ax2.grid(True, alpha=0.3)\n",
        "fig.tight_layout()\n",
        "fig.savefig(os.path.join(OUTPUT_DIR, \"2_riwayat_rmse_bayesian.png\"),\n",
        "            dpi=150, bbox_inches=\"tight\")\n",
        "plt.close(fig)\n",
        "print(\"    -> Tersimpan: 2_riwayat_rmse_bayesian.png\")\n",
        "\n",
        "# =============================================================================\n",
        "# 5. MELATIH MODEL FINAL\n",
        "# =============================================================================\n",
        "print(\"\\n[5] Melatih Model Final dengan Hiperparameter Terbaik...\")\n",
        "rf_final = RandomForestRegressor(\n",
        "    n_estimators      = best_params[\"n_estimators\"],\n",
        "    max_depth         = best_params[\"max_depth\"],\n",
        "    min_samples_split = best_params[\"min_samples_split\"],\n",
        "    min_samples_leaf  = best_params[\"min_samples_leaf\"],\n",
        "    max_features      = best_params[\"max_features\"],\n",
        "    oob_score=False, bootstrap=False, random_state=42, n_jobs=-1\n",
        ")\n",
        "rf_final.fit(X_train_sel, y_train)\n",
        "\n",
        "def evaluate(name, X, y_true):\n",
        "    y_pred = rf_final.predict(X)\n",
        "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
        "    mae  = mean_absolute_error(y_true, y_pred)\n",
        "    r2   = r2_score(y_true, y_pred)\n",
        "    print(f\"    {name:12s} -> RMSE={rmse:.4f}  MAE={mae:.4f}  R²={r2:.4f}\")\n",
        "    return y_pred, rmse, mae, r2\n",
        "\n",
        "print()\n",
        "y_train_pred, tr_rmse, tr_mae, tr_r2 = evaluate(\"Pelatihan\",  X_train_sel, y_train)\n",
        "y_val_pred,   vl_rmse, vl_mae, vl_r2 = evaluate(\"Validasi\",   X_val_sel,   y_val)\n",
        "y_test_pred,  ts_rmse, ts_mae, ts_r2 = evaluate(\"Pengujian\",  X_test_sel,  y_test)\n",
        "\n",
        "# =============================================================================\n",
        "# 6. LAI TERAMATI VS TERPREDIKSI\n",
        "# =============================================================================\n",
        "print(\"\\n[6] Membuat plot LAI Teramati vs Terprediksi...\")\n",
        "\n",
        "def plot_obs_vs_pred(splits, filename, label_samples=False, num_arrays=None):\n",
        "    fig, axes = plt.subplots(1, 3, figsize=(18 if label_samples else 15, 6))\n",
        "    for ax, (name, obs, pred, rmse, r2, color) in zip(axes, splits):\n",
        "        all_v = np.concatenate([obs, pred])\n",
        "        mn, mx = all_v.min(), all_v.max()\n",
        "        pad = (mx - mn) * 0.08\n",
        "\n",
        "        ax.scatter(obs, pred, color=color, alpha=0.7, s=55,\n",
        "                   edgecolors=\"white\", linewidths=0.5, zorder=3)\n",
        "\n",
        "        # Label nomor sampel (opsional)\n",
        "        if label_samples and num_arrays is not None:\n",
        "            nums = num_arrays[name]\n",
        "            for xi, yi, ni in zip(obs, pred, nums):\n",
        "                ax.annotate(str(int(ni)),\n",
        "                            xy=(xi, yi), xytext=(4, 4),\n",
        "                            textcoords=\"offset points\",\n",
        "                            fontsize=6.5, color=\"#333333\",\n",
        "                            fontweight=\"bold\", zorder=4)\n",
        "\n",
        "        # Garis 1:1\n",
        "        ax.plot([mn-pad, mx+pad], [mn-pad, mx+pad],\n",
        "                \"k--\", linewidth=1.5, label=\"Garis 1:1\", zorder=2)\n",
        "\n",
        "        # Garis regresi\n",
        "        sl, ic, r, p, se = linregress(obs, pred)\n",
        "        xfit = np.array([mn - pad, mx + pad])\n",
        "        ax.plot(xfit, sl * xfit + ic,\n",
        "                color=color, linewidth=1.8, linestyle=\"-\",\n",
        "                label=f\"Regresi: y={sl:.3f}x+{ic:.3f}\", zorder=2)\n",
        "\n",
        "        # Anotasi statistik\n",
        "        ax.annotate(\n",
        "            f\"R² = {r2:.4f}\\nRMSE = {rmse:.4f}\\nn = {len(obs)}\",\n",
        "            xy=(0.05, 0.88), xycoords=\"axes fraction\",\n",
        "            fontsize=8, color=color, fontweight=\"bold\",\n",
        "            bbox=dict(boxstyle=\"round,pad=0.35\", fc=\"white\", ec=color, alpha=0.88)\n",
        "        )\n",
        "\n",
        "        ax.set_xlabel(\"LAI Teramati\", fontsize=10)\n",
        "        ax.set_ylabel(\"LAI Terprediksi\", fontsize=10)\n",
        "        ax.set_title(f\"{name}\\nRMSE={rmse:.4f}  R²={r2:.4f}\",\n",
        "                     fontsize=11, fontweight=\"bold\")\n",
        "        ax.set_xlim(mn - pad, mx + pad)\n",
        "        ax.set_ylim(mn - pad, mx + pad)\n",
        "        ax.set_aspect(\"equal\")\n",
        "        ax.legend(fontsize=7.5)\n",
        "        ax.grid(True, alpha=0.3)\n",
        "        ax.spines[\"top\"].set_visible(False)\n",
        "        ax.spines[\"right\"].set_visible(False)\n",
        "\n",
        "    suffix = \" (dengan Nomor Sampel)\" if label_samples else \"\"\n",
        "    fig.suptitle(f\"Prediksi LAI Random Forest -- Teramati vs Terprediksi{suffix}\",\n",
        "                 fontsize=13, fontweight=\"bold\")\n",
        "    fig.tight_layout()\n",
        "    fig.savefig(os.path.join(OUTPUT_DIR, filename), dpi=150, bbox_inches=\"tight\")\n",
        "    plt.close(fig)\n",
        "    print(f\"    -> Tersimpan: {filename}\")\n",
        "\n",
        "# Data training asli (sebelum oversampling) untuk plot berlabel\n",
        "y_train_orig      = train_df_orig[y_col].values.astype(float)\n",
        "X_train_orig      = train_df_orig[selected_features].values.astype(float)\n",
        "y_train_orig_pred = rf_final.predict(X_train_orig)\n",
        "\n",
        "splits_plot = [\n",
        "    (\"Pelatihan\",  y_train,      y_train_pred, tr_rmse, tr_r2, \"#2ecc71\"),\n",
        "    (\"Validasi\",   y_val,        y_val_pred,   vl_rmse, vl_r2, \"#3498db\"),\n",
        "    (\"Pengujian\",  y_test,       y_test_pred,  ts_rmse, ts_r2, \"#e74c3c\"),\n",
        "]\n",
        "\n",
        "splits_orig = [\n",
        "    (\"Pelatihan\",  y_train_orig, y_train_orig_pred, tr_rmse, tr_r2, \"#2ecc71\"),\n",
        "    (\"Validasi\",   y_val,        y_val_pred,        vl_rmse, vl_r2, \"#3498db\"),\n",
        "    (\"Pengujian\",  y_test,       y_test_pred,       ts_rmse, ts_r2, \"#e74c3c\"),\n",
        "]\n",
        "\n",
        "# Nomor sampel per split\n",
        "num_arrays = {\n",
        "    \"Pelatihan\": train_df_orig[num_col].values,\n",
        "    \"Validasi\":  val_df[num_col].values,\n",
        "    \"Pengujian\": test_df[num_col].values,\n",
        "}\n",
        "\n",
        "# Plot A: tanpa label nomor\n",
        "plot_obs_vs_pred(splits_plot, \"3_teramati_vs_terprediksi.png\",\n",
        "                 label_samples=False)\n",
        "\n",
        "# Plot B: dengan label nomor sampel (pakai data asli training)\n",
        "plot_obs_vs_pred(splits_orig, \"3b_teramati_vs_terprediksi_label.png\",\n",
        "                 label_samples=True, num_arrays=num_arrays)\n",
        "\n",
        "# =============================================================================\n",
        "# 8. PENTINGNYA FITUR MODEL FINAL\n",
        "# =============================================================================\n",
        "print(\"\\n[8] Pentingnya Fitur Model Final...\")\n",
        "final_imp = pd.DataFrame({\n",
        "    \"Fitur\":      selected_features,\n",
        "    \"Pentingnya\": rf_final.feature_importances_\n",
        "}).sort_values(\"Pentingnya\", ascending=False).reset_index(drop=True)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9, 5))\n",
        "palette = plt.cm.RdYlGn(np.linspace(0.3, 0.9, len(final_imp)))[::-1]\n",
