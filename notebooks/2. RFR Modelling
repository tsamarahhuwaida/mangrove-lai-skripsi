        "plt.close(fig)\n",
        "print(\"    -> Tersimpan: 6_analisis_residual.png\")\n",
        "\n",
        "print(f\"\\n    {'Metrik':<22} {'Pelatihan':>12} {'Validasi':>12} {'Pengujian':>12}\")\n",
