      "cell_type": "code",
      "source": [
        ",\"\"\"\n",
        "=============================================================================\n",
        "Apply Saved Random Forest Model (.pkl) to GeoTIFF Imagery\n",
        "Output: LAI Prediction Raster (.tif)\n",
        "=============================================================================\n",
        "Requirements:\n",
        "  pip install rasterio numpy joblib scikit-learn\n",
        "=============================================================================\n",
        "\"\"\"\n",
        "\n",
        "import numpy as np\n",
        "import joblib\n",
        "import os\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "try:\n",
        "    import rasterio\n",
        "except ImportError:\n",
        "    raise ImportError(\"Install rasterio first:  pip install rasterio\")\n",
        "\n",
        "# =============================================================================\n",
        "# 0. CONFIGURATION -- EDIT THESE\n",
        "# =============================================================================\n",
        "\n",
        "MODEL_PKL    = \"/content/drive/MyDrive/01-SKRIPSI PIF LAI CMC/04. BAB 4 - HASIL/04.05. RF/04.05.02. Hasil RF/(7th attempt) Sample Coordinate Repair_Improved Residual No Bootstrap With validation, final model just using the training sample/rf_lai_final_model.pkl\"    # ← path to your saved model\n",
        "FEATURES_PKL = \"/content/drive/MyDrive/01-SKRIPSI PIF LAI CMC/04. BAB 4 - HASIL/04.05. RF/04.05.02. Hasil RF/(7th attempt) Sample Coordinate Repair_Improved Residual No Bootstrap With validation, final model just using the training sample/selected_features.pkl\"    # ← path to saved feature list\n",
        "                                           #   set None if not saved\n",
        "IMAGE_PATH   = \"/content/drive/MyDrive/01-SKRIPSI PIF LAI CMC/04. BAB 4 - HASIL/04.05. RF/04.05.03. Reproduce LAI/(2)PIF_Harmonized/TIFF_Watermasked/2025_stacked_masked.tif\"         # ← your input GeoTIFF\n",
        "OUTPUT_TIF   = \"/content/drive/MyDrive/01-SKRIPSI PIF LAI CMC/04. BAB 4 - HASIL/04.05. RF/04.05.03. Reproduce LAI/(2)PIF_Harmonized/LAI Result2025new_lai_predicted.tif\"        # ← output LAI raster\n",
        "\n",
        "# Map each feature name (must match training column names exactly)\n",
        "# to its band index in the GeoTIFF (1-based)\n",
        "BAND_MAP = {\n",
        "    \"Band_1\": 1,    # ← e.g. Blue\n",
        "    \"Band_2\": 2,    # ← e.g. Green\n",
        "    \"Band_3\": 3,    # ← e.g. Red\n",
        "    \"Band_4\": 4,    # ← e.g. NIR\n",
        "    \"NDVI\":  5,    # ← remove these VI entries if VIs are not\n",
        "    \"EVI\":   6,    #   bands in your image (set COMPUTE_VIS=True)\n",
        "    \"SAVI\":  7,\n",
        "    \"ARVI \": 8,\n",
        "}\n",
        "\n",
        "# Set True if VIs are NOT bands in the image — script will compute them\n",
        "COMPUTE_VIS   = False\n",
        "RED_BAND_IDX  = 3    # 1-based band index of Red  (used if COMPUTE_VIS=True)\n",
        "NIR_BAND_IDX  = 4    # 1-based band index of NIR\n",
        "BLUE_BAND_IDX = 1    # 1-based band index of Blue (needed for EVI)\n",
        "\n",
        "# Pixels to exclude from prediction\n",
        "NODATA_VALUE = 0      # pixel value treated as no-data (set None to disable)\n",
        "VALID_RANGE  = (0, 1) # valid reflectance range — pixels outside are masked\n",
        "                      # set None to disable\n",
        "\n",
        "OUTPUT_NODATA = -9999  # nodata value written to output raster\n",
        "CHUNK_SIZE    = 100_000  # number of pixels predicted at once (memory control)\n",
        "\n",
        "# =============================================================================\n",
        "# 1. LOAD MODEL AND FEATURE LIST\n",
        "# =============================================================================\n",
        "print(\"=\" * 60)\n",
        "print(\"  APPLYING RF MODEL TO GEOTIFF IMAGERY\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "print(\"\\n[1] Loading model...\")\n",
        "rf_model = joblib.load(MODEL_PKL)\n",
        "print(f\"    Model     : {MODEL_PKL}\")\n",
        "print(f\"    Trees     : {rf_model.n_estimators}\")\n",
        "\n",
        "if FEATURES_PKL and os.path.exists(FEATURES_PKL):\n",
        "    selected_features = joblib.load(FEATURES_PKL)\n",
        "else:\n",
        "    selected_features = list(BAND_MAP.keys())\n",
        "print(f\"    Features  : {selected_features}\")\n",
        "\n",
        "# =============================================================================\n",
        "# 2. LOAD IMAGERY\n",
        "# =============================================================================\n",
        "print(f\"\\n[2] Loading imagery...\")\n",
        "\n",
        "with rasterio.open(IMAGE_PATH) as src:\n",
        "    profile   = src.profile\n",
        "    height    = src.height\n",
        "    width     = src.width\n",
        "    nodata    = src.nodata\n",
        "    print(f\"    File      : {IMAGE_PATH}\")\n",
        "    print(f\"    Size      : {width} x {height} pixels\")\n",
        "    print(f\"    Bands     : {src.count}\")\n",
        "    print(f\"    CRS       : {src.crs}\")\n",
        "\n",
        "    # Read bands needed for selected features\n",
        "    band_data = {}\n",
        "    for feat in selected_features:\n",
        "        if feat in BAND_MAP:\n",
        "            band_data[feat] = src.read(BAND_MAP[feat]).astype(float)\n",
        "\n",
        "# =============================================================================\n",
        "# 4. BUILD VALID PIXEL MASK\n",
        "# =============================================================================\n",
        "print(\"\\n[4] Building pixel mask...\")\n",
        "\n",
        "mask = np.ones((height, width), dtype=bool)\n",
        "\n",
        "if NODATA_VALUE is not None:\n",
        "    for arr in band_data.values():\n",
        "        mask &= (arr != NODATA_VALUE)\n",
        "\n",
        "if nodata is not None:\n",
        "    for arr in band_data.values():\n",
        "        mask &= (arr != nodata)\n",
        "\n",
        "if VALID_RANGE is not None:\n",
        "    for arr in band_data.values():\n",
        "        mask &= (arr >= VALID_RANGE[0]) & (arr <= VALID_RANGE[1])\n",
        "\n",
        "for arr in band_data.values():\n",
        "    mask &= np.isfinite(arr)\n",
        "\n",
        "n_valid = mask.sum()\n",
        "n_total = height * width\n",
        "print(f\"    Valid pixels : {n_valid:,} / {n_total:,} \"\n",
        "      f\"({100 * n_valid / n_total:.1f}%)\")\n",
        "\n",
        "# =============================================================================\n",
        "# 5. PREDICT LAI\n",
        "# =============================================================================\n",
        "print(\"\\n[5] Predicting LAI...\")\n",
        "\n",
        "# Stack features in the correct order for valid pixels only\n",
        "feature_matrix = np.stack(\n",
        "    [band_data[feat][mask] for feat in selected_features], axis=1\n",
        ")\n",
        "\n",
        "# Predict in chunks to handle large images without memory issues\n",
        "n_pixels = feature_matrix.shape[0]\n",
        "lai_flat = np.zeros(n_pixels, dtype=float)\n",
        "\n",
        "for start in range(0, n_pixels, CHUNK_SIZE):\n",
        "    end = min(start + CHUNK_SIZE, n_pixels)\n",
        "    lai_flat[start:end] = rf_model.predict(feature_matrix[start:end])\n",
        "    print(f\"    {end:,} / {n_pixels:,} pixels  \"\n",
        "          f\"({100 * end / n_pixels:.1f}%)\", end=\"\\r\")\n",
        "\n",
        "print(f\"\\n    Done.\")\n",
        "print(f\"    LAI min  : {lai_flat.min():.4f}\")\n",
        "print(f\"    LAI max  : {lai_flat.max():.4f}\")\n",
        "print(f\"    LAI mean : {lai_flat.mean():.4f}\")\n",
        "print(f\"    LAI std  : {lai_flat.std():.4f}\")\n",
        "\n",
        "# Reconstruct full image grid\n",
        "lai_image = np.full((height, width), np.nan, dtype=float)\n",
        "lai_image[mask] = lai_flat\n",
        "\n",
        "# =============================================================================\n",
        "# 6. SAVE OUTPUT RASTER\n",
        "# =============================================================================\n",
        "print(f\"\\n[6] Saving output raster...\")\n",
        "\n",
        "out_profile = profile.copy()\n",
        "out_profile.update({\n",
        "    \"count\":    1,\n",
        "    \"dtype\":    \"float32\",\n",
        "    \"nodata\":   OUTPUT_NODATA,\n",
        "    \"compress\": \"lzw\",\n",
        "})\n",
        "\n",
        "lai_out = lai_image.astype(\"float32\")\n",
        "lai_out[np.isnan(lai_image)] = OUTPUT_NODATA\n",
        "\n",
        "with rasterio.open(OUTPUT_TIF, \"w\", **out_profile) as dst:\n",
        "    dst.write(lai_out, 1)\n",
        "\n",
        "print(f\"    -> Saved: {OUTPUT_TIF}\")\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(f\"  Predicted LAI raster saved to: {OUTPUT_TIF}\")\n",
        "print(f\"  Valid pixels : {n_valid:,}\")\n",
        "print(f\"  LAI range    : {lai_flat.min():.3f} – {lai_flat.max():.3f}\")\n",
        "print(\"=\" * 60)"
      ],
