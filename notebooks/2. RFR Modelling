        "ax.set_xlabel(\"Pentingnya Fitur (Rata-rata Penurunan Impuritas)\", fontsize=11)\n",
        "ax.set_title(\"Pentingnya Fitur Model Final\\n\"\n",
        "             f\"(n_estimators={best_params['n_estimators']}, \"\n",
        "             f\"max_depth={best_params['max_depth']})\",\n",
        "             fontsize=12, fontweight=\"bold\")\n",
        "ax.set_xlim(0, final_imp[\"Pentingnya\"].max() * 1.25)\n",
        "ax.grid(True, axis=\"x\", alpha=0.3)\n",
        "fig.tight_layout()\n",
        "fig.savefig(os.path.join(OUTPUT_DIR, \"5_pentingnya_fitur_final.png\"),\n",
        "            dpi=150, bbox_inches=\"tight\")\n",
        "plt.close(fig)\n",
        "print(\"    -> Tersimpan: 5_pentingnya_fitur_final.png\")\n",
        "\n",
        "# =============================================================================\n",
        "# 9. ANALISIS RESIDUAL\n",
        "# =============================================================================\n",
        "print(\"\\n[9] Analisis Residual...\")\n",
        "resid_train = y_train - y_train_pred\n",
        "resid_val   = y_val   - y_val_pred\n",
        "resid_test  = y_test  - y_test_pred\n",
        "\n",
        "fig = plt.figure(figsize=(18, 14))\n",
        "gs  = GridSpec(3, 3, figure=fig, hspace=0.45, wspace=0.35)\n",
        "\n",
        "splits_resid = [\n",
        "    (\"Pelatihan\",  y_train_pred, resid_train, \"#2ecc71\"),\n",
        "    (\"Validasi\",   y_val_pred,   resid_val,   \"#3498db\"),\n",
        "    (\"Pengujian\",  y_test_pred,  resid_test,  \"#e74c3c\"),\n",
        "]\n",
        "\n",
        "for col, (name, pred, resid, color) in enumerate(splits_resid):\n",
        "    ax = fig.add_subplot(gs[0, col])\n",
        "    ax.scatter(pred, resid, color=color, alpha=0.75, s=55,\n",
        "               edgecolors=\"white\", linewidths=0.5)\n",
        "    ax.axhline(0, color=\"black\", linewidth=1.5, linestyle=\"--\")\n",
        "    std = resid.std()\n",
        "    ax.axhline( std, color=color, linewidth=1, linestyle=\":\", alpha=0.7, label=f\"+1σ ({std:.3f})\")\n",
        "    ax.axhline(-std, color=color, linewidth=1, linestyle=\":\", alpha=0.7, label=f\"-1σ ({-std:.3f})\")\n",
        "    ax.set_xlabel(\"LAI Terprediksi\", fontsize=9)\n",
        "    ax.set_ylabel(\"Residual (Teramati − Terprediksi)\", fontsize=9)\n",
        "    ax.set_title(f\"{name}\\nResidual vs Terprediksi\", fontsize=10, fontweight=\"bold\")\n",
        "    ax.legend(fontsize=7)\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "for col, (name, pred, resid, color) in enumerate(splits_resid):\n",
        "    ax = fig.add_subplot(gs[1, col])\n",
        "    ax.hist(resid, bins=15, color=color, alpha=0.7, edgecolor=\"white\", density=True)\n",
        "    mu_r, std_r = resid.mean(), resid.std()\n",
        "    x_norm = np.linspace(resid.min(), resid.max(), 200)\n",
        "    ax.plot(x_norm, norm.pdf(x_norm, mu_r, std_r),\n",
        "            color=\"black\", linewidth=2, label=f\"N(μ={mu_r:.3f}, σ={std_r:.3f})\")\n",
        "    ax.axvline(0,    color=\"black\",  linewidth=1.5, linestyle=\"--\")\n",
        "    ax.axvline(mu_r, color=\"orange\", linewidth=1.5, linestyle=\"-.\", label=f\"Rata-rata={mu_r:.3f}\")\n",
        "    ax.set_xlabel(\"Residual\", fontsize=9)\n",
        "    ax.set_ylabel(\"Densitas\", fontsize=9)\n",
        "    ax.set_title(f\"{name}\\nDistribusi Residual\", fontsize=10, fontweight=\"bold\")\n",
        "    ax.legend(fontsize=7)\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "for col, (name, pred, resid, color) in enumerate(splits_resid):\n",
        "    ax = fig.add_subplot(gs[2, col])\n",
        "    (osm, osr), (slope, intercept, r) = probplot(resid, dist=\"norm\")\n",
        "    ax.scatter(osm, osr, color=color, alpha=0.75, s=45,\n",
        "               edgecolors=\"white\", linewidths=0.5)\n",
        "    x_line = np.array([osm.min(), osm.max()])\n",
        "    ax.plot(x_line, slope * x_line + intercept,\n",
        "            color=\"black\", linewidth=1.8, linestyle=\"--\", label=f\"R²={r**2:.4f}\")\n",
        "    ax.set_xlabel(\"Kuantil Teoretis\", fontsize=9)\n",
        "    ax.set_ylabel(\"Kuantil Sampel\", fontsize=9)\n",
        "    ax.set_title(f\"{name}\\nPlot Q-Q\", fontsize=10, fontweight=\"bold\")\n",
        "    ax.legend(fontsize=7)\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "fig.suptitle(\"Analisis Residual -- Prediksi LAI Random Forest\",\n",
        "             fontsize=14, fontweight=\"bold\")\n",
        "fig.savefig(os.path.join(OUTPUT_DIR, \"6_analisis_residual.png\"),\n",
        "            dpi=150, bbox_inches=\"tight\")\n",
        "plt.close(fig)\n",
        "print(\"    -> Tersimpan: 6_analisis_residual.png\")\n",
        "\n",
        "print(f\"\\n    {'Metrik':<22} {'Pelatihan':>12} {'Validasi':>12} {'Pengujian':>12}\")\n",
        "print(\"    \" + \"-\" * 60)\n",
        "for metrik, vals in {\n",
        "    \"Rata-rata\":   [resid_train.mean(),  resid_val.mean(),  resid_test.mean()],\n",
        "    \"Std Dev\":     [resid_train.std(),   resid_val.std(),   resid_test.std()],\n",
        "    \"Minimum\":     [resid_train.min(),   resid_val.min(),   resid_test.min()],\n",
        "    \"Maksimum\":    [resid_train.max(),   resid_val.max(),   resid_test.max()],\n",
        "    \"% |e| < 0.5\": [np.mean(np.abs(resid_train)<0.5)*100,\n",
        "                    np.mean(np.abs(resid_val)<0.5)*100,\n",
        "                    np.mean(np.abs(resid_test)<0.5)*100],\n",
        "}.items():\n",
        "    unit = \"%\" if \"%\" in metrik else \"\"\n",
        "    print(f\"    {metrik:<22} {vals[0]:>11.4f}{unit} {vals[1]:>11.4f}{unit} {vals[2]:>11.4f}{unit}\")\n",
        "\n",
        "# =============================================================================\n",
        "# 10. DASBOR RINGKASAN\n",
        "# =============================================================================\n",
        "print(\"\\n[10] Dasbor Ringkasan...\")\n",
        "fig = plt.figure(figsize=(14, 7))\n",
        "gs  = GridSpec(2, 3, figure=fig, hspace=0.45, wspace=0.35)\n",
        "\n",
        "ax_m = fig.add_subplot(gs[:, 0])\n",
        "metric_labels = [\"RMSE Pelatihan\",\"RMSE Validasi\",\"RMSE Pengujian\",\n",
        "                 \"R² Pelatihan\",\"R² Validasi\",\"R² Pengujian\"]\n",
        "metric_values = [tr_rmse, vl_rmse, ts_rmse, tr_r2, vl_r2, ts_r2]\n",
        "m_colors = [\"#2ecc71\"]*3 + [\"#3498db\"]*3\n",
